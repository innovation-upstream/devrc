# audit-on-push config — copy to ~/.claude/audit-on-push.env
#
# Master flag. Default is shadow (safe). States:
#   off    — do nothing
#   shadow — run the audit, LOG what it would surface, send NOTHING (default)
#   on     — actually POST 🔴/🟡 findings to clawgate (your phone)
AUDIT_ON_PUSH=shadow

# Skip the audit when the pushed diff (HEAD vs merge-base with the default
# branch) changes fewer than this many lines.
AUDIT_MIN_LINES=40

# Seconds budget for the headless `claude -p` audit call (it is backgrounded,
# so this never delays the push; it only bounds the LLM run).
AUDIT_TIMEOUT=300

# Where shadow/decision logging goes.
AUDIT_LOG_FILE=~/.claude/audit-on-push.log

# clawgate creds are reused from ~/.claude/clawgate.env automatically; only set
# these here to override.
# CLAWGATE_API_URL=http://192.168.50.250:30302
# CLAWGATE_HOOK_TOKEN=
