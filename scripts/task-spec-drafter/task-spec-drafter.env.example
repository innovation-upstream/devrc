# task-spec-drafter config — copy to ~/.claude/task-spec-drafter.env
#
# Master flag. Default is shadow (safe). States:
#   off    — do nothing
#   shadow — run the full pipeline, write the queue, LOG what it would send to
#            clawgate, send NOTHING (default)
#   on     — actually POST the triage summary to clawgate (your phone)
DRAFTER_MODE=shadow

# Model for the per-ticket headless `claude -p` pass. Alias (haiku|sonnet|opus)
# or a full model id. Default is haiku (cheap). The deterministic safety gate in
# drafter.sh compensates for Haiku's measured intent-ambiguity blind spot, so the
# dangerous classes (security/secrets, money, destructive/prod-mutation) are
# force-escalated to NEEDS-DECISION in code regardless of the model.
DRAFTER_MODEL=haiku

# Cap tickets processed per run (0 = all). Useful for cheap test runs.
DRAFTER_MAX_TICKETS=0

# Seconds budget per ticket's headless `claude -p` deep-context call.
DRAFTER_TIMEOUT=240

# Where shadow queues + the run log are written.
DRAFTER_OUT_DIR=~/.claude/task-spec-drafter

# ClickUp triage view to read (default = the "To Schedule" standup queue).
CLICKUP_VIEW_ID=6-901111220963-1

# Verification sources (override only if your checkouts move).
# CIVITAI_REPO=/home/zach/workspace/civit/civitai
# PROD_KUBECONFIG=/home/zach/workspace/civit/datapacket-talos/prod-kubeconfig

# clawgate creds are reused from ~/.claude/clawgate.env automatically; set here
# only to override.
# CLAWGATE_API_URL=http://192.168.50.250:30302
# CLAWGATE_HOOK_TOKEN=
