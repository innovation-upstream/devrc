#!/usr/bin/env bash
# Interactive half of the Mullvad VPN block, invoked from i3status-rust via
# [[block.click]] (left-click). Shows a rofi menu: refresh / switch server /
# toggle VPN / status details. The privileged actions (config rewrite +
# nixos-rebuild, wg service up/down) are delegated to the vpn-sudo helper run
# under a NOPASSWD sudoers rule.
#
# Split out of the old scripts/i3blocks-vpn: this file is the click handler,
# scripts/i3status-vpn-status is the render half.
#
# vpn-sudo path: kept at the STABLE, sudoers-trusted path (see below). The
# NOPASSWD rule in /etc/nixos/configuration.nix authorizes exactly this path;
# a nix-store path would (a) not match the rule and (b) change on every rebuild.
# Override with $VPN_SUDO_HELPER if you relocate it.
set -uo pipefail

WG_IFACE="mullvad"
CACHE_FILE="/tmp/i3status-vpn-cache"
SERVER_CACHE="/tmp/i3status-vpn-servers"
SERVER_CACHE_TTL=3600
SCRIPT_BASE="$(dirname "$(readlink -f "$0")")"
SUDO_HELPER="${VPN_SUDO_HELPER:-/etc/nixos/i3blocks-scripts/vpn-sudo}"
FLOAT_TERM="alacritty --class float,float -e"

# Force the render block to refresh now.
refresh_bar() { pkill -RTMIN+10 i3status-rs; }

fetch_servers() {
    if [[ -f "$SERVER_CACHE" ]]; then
        age=$(( $(date +%s) - $(stat -c %Y "$SERVER_CACHE") ))
        if (( age < SERVER_CACHE_TTL )); then
            cat "$SERVER_CACHE"
            return
        fi
    fi
    curl -s --max-time 10 https://api.mullvad.net/www/relays/wireguard/ 2>/dev/null | python3 -c "
import json, sys
relays = json.load(sys.stdin)
for r in sorted(relays, key=lambda x: (x['country_name'], x['city_name'], x['hostname'])):
    if r['active']:
        print(f\"{r['hostname']}|{r['ipv4_addr_in']}|{r['pubkey']}|{r['city_name']}, {r['country_name']}\")
" 2>/dev/null | tee "$SERVER_CACHE"
}

apply_server() {
    local hostname="$1" ip="$2" pubkey="$3"
    local old_ip old_pubkey
    old_ip=$(grep -v '#' /etc/nixos/configuration.nix | grep -oP '(?<=endpoint = ")\d[\d.]+(?=:)')
    old_pubkey=$(grep -v '#' /etc/nixos/configuration.nix | grep -oP '(?<=publicKey = ")[^"]+(?=")')

    if [[ -z "$old_ip" || -z "$old_pubkey" ]]; then
        notify-send -u critical -t 5000 "VPN" "Failed to parse current config"
        return 1
    fi

    notify-send -t 3000 "VPN" "Switching to $hostname..."
    if sudo "$SUDO_HELPER" switch "$old_ip" "$ip" "$old_pubkey" "$pubkey" 2>/tmp/vpn-switch.log; then
        rm -f "$CACHE_FILE"
        notify-send -t 5000 "VPN" "Switched to $hostname"
        refresh_bar
    else
        notify-send -u critical -t 10000 "VPN" "Failed: $(tail -3 /tmp/vpn-switch.log)"
    fi
}

toggle_vpn() {
    local state
    state=$(ip link show "$WG_IFACE" 2>/dev/null | grep -o 'UP')
    if [[ "$state" == "UP" ]]; then
        sudo "$SUDO_HELPER" down
        notify-send -t 3000 "VPN" "Disabled"
    else
        sudo "$SUDO_HELPER" up
        notify-send -t 3000 "VPN" "Enabled"
    fi
    rm -f "$CACHE_FILE"
    refresh_bar
}

rofi_menu() {
    local toggle_label="Disable VPN"
    if ! ip link show "$WG_IFACE" 2>/dev/null | grep -q 'UP'; then
        toggle_label="Enable VPN"
    fi

    local choice
    choice=$(printf '%s\n' "Refresh" "Switch Server" "$toggle_label" "Status Details" \
        | rofi -dmenu -p "VPN" -theme gruvbox-dark-hard -i)

    case "$choice" in
        "Refresh")
            rm -f "$CACHE_FILE"
            refresh_bar
            ;;
        "Switch Server")
            local servers server_line hostname ip pubkey
            servers=$(fetch_servers)
            if [[ -z "$servers" ]]; then
                notify-send -t 3000 "VPN" "Failed to fetch server list"
                return
            fi
            server_line=$(echo "$servers" | awk -F'|' '{printf "%-20s  %s\n", $1, $4}' \
                | rofi -dmenu -p "Server" -theme gruvbox-dark-hard -i -matching fuzzy)
            [[ -z "$server_line" ]] && return
            hostname=$(echo "$server_line" | awk '{print $1}')
            local record
            record=$(grep "^${hostname}|" "$SERVER_CACHE")
            ip=$(echo "$record" | cut -d'|' -f2)
            pubkey=$(echo "$record" | cut -d'|' -f3)
            apply_server "$hostname" "$ip" "$pubkey"
            ;;
        "Disable VPN"|"Enable VPN")
            toggle_vpn
            ;;
        "Status Details")
            i3-msg -q exec "$FLOAT_TERM ${SCRIPT_BASE}/vpn-detail"
            ;;
    esac
}

rofi_menu
