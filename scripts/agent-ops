_SLOT_RE = re.compile(r'"([^":]+):([^":]+):(#[0-9a-fA-F]{6}):([^":]+)"')

REFRESH = float(os.environ.get("AGENT_OPS_REFRESH", "4"))
CLAUDE_RE = re.compile(r"claude", re.IGNORECASE)
